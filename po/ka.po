#: src/qalc.cc:6845
msgid "Create a variable with the specified name and expression."
msgstr "ცვლადის შექმნა მითითებული სახელითა და გამოსახულებით."

#: src/qalc.cc:6847
msgid "Example: variable var1 pi / 2."
msgstr "მაგალითად: variable var1 pi / 2."

#: src/qalc.cc:6851
msgid "Creates a function with the specified name and expression."
msgstr "ფუნქციის შექმნა მითითებული სახელითა და გამოსახულებით."

#: src/qalc.cc:6852
msgid "Use '\\x', '\\y', '\\z', '\\a', etc. for arguments in the expression."
msgstr ""
"გამოსახულებაში არგუმენტებად '\\x', '\\y', '\\z', '\\a' და ა.შ. გამოყენება "
"შეგიძლიათ."

#: src/qalc.cc:6854
msgid "Example: function func1 5*\\x."
msgstr "მაგალითად: function func1 5*\\x."

#: src/qalc.cc:6858
msgid "Removes the user-defined variable or function with the specified name."
msgstr ""
"მითითებული სახელის მქონე არა-მომხარებლის მიერ აღწერილი ცვლადის ან ფუნქციის "
"წაშლა."

#: src/qalc.cc:6860
msgid "Example: delete var1."
msgstr "მაგალითად: delete var1."

#: src/qalc.cc:6864
msgid ""
"Make the temporary user-defined variable or function with the specified name "
"non-temporary."
msgstr ""
"მითითებული სახელის დროებითი მომხმარებლის აღწერილი ცვლადის, ან ფუნქციის "
"გადაკეთება არადროებითად."

#: src/qalc.cc:6866
msgid "Example: keep var1."
msgstr "მაგ: keep var1."

#: src/qalc.cc:6870
msgid "Displays the current mode."
msgstr "მიმდინარე რეჟიმის ჩვენება."

#: src/qalc.cc:6874
msgid "Displays a list of variables, functions, units, and prefixes."
msgstr "ცვლადების, ფუნქციების, ერთეულებისა და პრეფიქსების ჩვენება."

#: src/qalc.cc:6875
msgid ""
"Enter with argument 'currencies', 'functions', 'variables', 'units', or "
"'prefixes' to show a list of all currencies, functions, variables, units, or "
"prefixes. Enter a search term to find matching variables, functions, units, "
"and/or prefixes. If command is called with no argument all user-defined "
"objects are listed."
msgstr ""
"შეიყვანეთ არგუმენტით 'currencies', 'functions', 'variables', 'units', ან "
"'prefixes' ვალუტების, ფუნქციების, ცვადების, ერთეულების, ან პრეფიქსების "
"გამოსატანად. შეიყვანეთ საძებნის სტრიქონი, რომ იპოვოთ შესაბამისი ცვლადები, "
"ფუნქციები, ერთეულები ან/და პრეფიქსები. თუ ბრძანება არგუმენტის გარეშეა "
"გამოძახებული, ჩამოთვლილი იქნება ყველა მომხმარებლის აღწერილი ობიექტი."

#: src/qalc.cc:6877
msgid "Example: list functions."
msgstr "მაგალითად: list functions."

#: src/qalc.cc:6878
msgid "Example: find dinar."
msgstr "მაგალითად: find dinar."

#: src/qalc.cc:6879
msgid "Example: find variables planck."
msgstr "მაგალითად: find variables planck."

#: src/qalc.cc:6883
msgid "Displays information about a function, variable, unit, or prefix."
msgstr ""
"ფუნქციის, ცვლადის, ერთეულისა და პრეფიქსის შესახებ ინფორმაციის გამოტანა."

#: src/qalc.cc:6885
msgid "Example: info sin."
msgstr "მაგალითად: info sin."

#: src/qalc.cc:6889
msgid "Downloads current exchange rates from the Internet."
msgstr "ინტერნეტიდან ვალუტის მიმდინარე კურსების გადმოწერა."

#: src/qalc.cc:6893
msgid "(De)activates the Reverse Polish Notation stack and syntax."
msgstr "გათიშავს (ჩართავს) RPN-ის სტეკს და სინტაქსს."

#: src/qalc.cc:6895
msgid ""
"\"syntax\" activates only the RPN syntax and \"stack\" enables the RPN stack."
msgstr ""
"\"syntax\" ჩართავს RPN-ის მხოლოდ სინტაქსს და \"stack\" მის სტეკსაც ჩართავს."

#: src/qalc.cc:6896
msgid "\"on\" (1) and \"off\" (0) (de)activates both."
msgstr "\"on\" (1) და \"off\" (0) ორივეს (დე)აქტივაციას შეასრულებს."

#: src/qalc.cc:6900
msgid "Clears the entire RPN stack."
msgstr "RPN სტეკის მთლიანად გასუფთავება."

#: src/qalc.cc:6904
msgid "Removes the top of the RPN stack or the value at the specified index."
msgstr ""

#: src/qalc.cc:6906 src/qalc.cc:6918 src/qalc.cc:6928 src/qalc.cc:6938
msgid ""
"Index 1 is the top of stack and negative index values count from the bottom "
"of the stack."
msgstr ""

#: src/qalc.cc:6910
msgid "Displays the RPN stack."
msgstr "RPN-ის სტეკის ჩვენება."

#: src/qalc.cc:6914
msgid "Swaps position of values on the RPN stack."
msgstr "RPN სტეკზე მნიშვნელობების მდებარეობების მიმოცვლა."

#: src/qalc.cc:6916
msgid ""
"If no index is specified, the values on the top of the stack (index 1 and "
"index 2) will be swapped and if only one index is specified, the value at "
"this index will be swapped with the top value."
msgstr ""

#: src/qalc.cc:6920
msgid "Example: swap 2 4"
msgstr "მაგალითად: swap 2 4"

#: src/qalc.cc:6924
msgid "Duplicates a value on the RPN stack to the top of the stack."
msgstr ""

#: src/qalc.cc:6926
msgid "If no index is specified, the top of the stack is duplicated."
msgstr "თუ ინდექსი მითითებული არაა, სტეკის თავი დუბლირდება."

#: src/qalc.cc:6932
msgid "Rotates the RPN stack up (default) or down."
msgstr "RPN სტეკის მაღლა (ნაგულისხმევი) ან დაბლა მობრუნება."

#: src/qalc.cc:6936
msgid "Changes the position of a value on the RPN stack."
msgstr "RPN სტეკზე მნიშვნელობის მდებარეობის შეცვლა."

#: src/qalc.cc:6940
msgid "Example: move 2 4"
msgstr "მაგალითად: move 2 4"

#: src/qalc.cc:6944
msgid "Sets the result number base (equivalent to set base)."
msgstr "დააყენებს შედეგი რიცხვის ბაზას (იგივეა, რაც ფუძის დაყენება)."

#: src/qalc.cc:6948
msgid "Equivalent to set approximation exact."
msgstr "იგივეა, რაც \"set approximation exact\"."

#: src/qalc.cc:6952
msgid "Equivalent to set approximation try exact."
msgstr "იგივეა, რაც \"set approximation try exact\"."

#: src/qalc.cc:6957
msgid ""
"Converts the current result (equivalent to using \"to\" at the end of an "
"expression)."
msgstr ""
"მიმდინარე შედეგის გარდაქმნა (იგივე, რაც გამოსახულების ბოლოში \"to\"-ის "
"გამოყენება)."

#: src/qalc.cc:6959
msgid "Possible values:"
msgstr "შესაძლო მნიშვნელობები:"

#: src/qalc.cc:6961
msgid "- a unit or unit expression (e.g. meter or km/h)"
msgstr "- ერთეული ან ერთეულის გამოსახულება (მაგ: მეტრი ან კმ/სთ)"

#: src/qalc.cc:6962
msgid "prepend with ? to request the optimal prefix"
msgstr "ოპტიმალური პრეფიქსის გამოსათხოვად \"?\"-ით დაიწყეთ"

#: src/qalc.cc:6963
msgid "prepend with b? to request the optimal binary prefix"
msgstr "ოპტიმალური ბინარული პრეფიქსის გამოსათხოვად მოთხოვნა \"b?\"-ით დაიწყეთ"

#: src/qalc.cc:6964
msgid "prepend with + or - to force/disable use of mixed units"
msgstr "შერეული ერთეულების გამოსაყენებლად დაიწყეთ + ან - -ით"

#: src/qalc.cc:6965
msgid "- a variable or physical constant (e.g. c)"
msgstr "- ცვლადი ან ფიზიკური კონსტანტა (მაგ: c)"

#: src/qalc.cc:6966
msgid "- base (convert to base units)"
msgstr "- ძირითადი (ძირითად საზომ ერთეულებში გადაყვანა)"

#: src/qalc.cc:6967
msgid "- optimal (convert to optimal unit)"
msgstr "- ოპტიმალური (ოპტიმალურ ერთეულში გადაყვანა)"

#: src/qalc.cc:6968
msgid "- prefix (convert to optimal prefix)"
msgstr "- პრეფიქსი (ოპტიმალურ პრეფიქსში გადაყვანა)"

#: src/qalc.cc:6969
msgid "- mixed (convert to mixed units, e.g. hours + minutes)"
msgstr "- შერეული (შერეულ ერთეულებში გადაყვანა. მაგ: საათი + წუთები)"

#: src/qalc.cc:6971
msgid "- bin, binary (show as binary number)"
msgstr "- bin, binary (ორობით რიცხვად ჩვენება)"

#: src/qalc.cc:6972
msgid "- bin# (show as binary number with specified number of bits)"
msgstr "- bin# (ბინარული რიცხვის სახით ჩვენება მითითებული რაოდენობის ბიტებით)"

#: src/qalc.cc:6973
msgid "- oct, octal (show as octal number)"
msgstr "- oct, octal (რიცხვის რვაობით ფორმატში ჩვენება)"

#: src/qalc.cc:6974
msgid "- duo, duodecimal (show as duodecimal number)"
msgstr "- duo, duodecimal (რიცხვის თორმეტობით ფორმატში ჩვენება)"

#: src/qalc.cc:6975
msgid "- hex, hexadecimal (show as hexadecimal number)"
msgstr "- hex, hexadecimal (რიცხვის თექვსმეტობით ფორმატში ჩვენება)"

#: src/qalc.cc:6976
msgid "- hex# (show as hexadecimal number with specified number of bits)"
msgstr ""
"- hex# (ჩვენება თექვსმეტობითი რიცხვის სახით მითითებული ბიტების რაოდენობით)"

#: src/qalc.cc:6977
msgid "- sexa, sexa2, sexa3, sexagesimal (show as sexagesimal number)"
msgstr "- sexa, sexa2, sexagesimal (სამოცობითი რიცხვის სახით ჩვენება)"

#: src/qalc.cc:6978
msgid "- latitude, latitude2 (show as sexagesimal latitude)"
msgstr "- latitude, latitude2 (სამოცობითი განედის ჩვენება)"

#: src/qalc.cc:6979
msgid "- longitude, longitude2 (show as sexagesimal longitude)"
msgstr "- longitude, longitude2 (სამოცობითი გრძედის ჩვენება)"

#: src/qalc.cc:6980
msgid "- bijective (shown in bijective base-26)"
msgstr "- bijective (ნაჩვენებია ბიიექტურ base-26-ში)"

#: src/qalc.cc:6981
msgid "- fp16, fp32, fp64, fp80, fp128 (show in binary floating-point format)"
msgstr ""
"- fp16, fp32, fp64, fp80, fp128 (ბინარულ მცურავ-მძიმიან ფორმატში ჩვენება)"

#: src/qalc.cc:6982
msgid "- bcd (show as binary-coded decimal)"
msgstr "- bcd (ბინარულად-კოდირებული წილადის ჩვენება)"

#: src/qalc.cc:6983
msgid "- roman (show as roman numerals)"
msgstr "- რომაული (რომაული ციფრებით ჩვენება)"

#: src/qalc.cc:6984
msgid "- time (show in time format)"
msgstr "- დრო (დროის ფორმატში ჩვენება)"

#: src/qalc.cc:6985
msgid "- unicode"
msgstr "- უნიკოდი"

#: src/qalc.cc:6986
msgid "- base # (show in specified number base)"
msgstr "- base # (ჩვენება მითითებული რიცხვით სისტემაში)"

#: src/qalc.cc:6987
msgid "- bases (show as binary, octal, decimal and hexadecimal number)"
msgstr ""
"- bases (რიცხვის ჩვენება ორობითში, რვაობითში, ათობითში და თექვსმეტობითში)"

#: src/qalc.cc:6989
msgid "- rectangular, cartesian (show complex numbers in rectangular form)"
msgstr ""
"- rectangular, cartesian (კომპლექსური რიცხვების ჩვენება ოთხკუთხედ ფორმაში)"

#: src/qalc.cc:6990
msgid "- exponential (show complex numbers in exponential form)"
msgstr "- exponential (კომპლექსურ რიცხვების ექსპონენტურ ფორმაში ჩვენება)"

#: src/qalc.cc:6991
msgid "- polar (show complex numbers in polar form)"
msgstr "- polar (კომპლექსური რიცხვების პოლარულ ფორმაში ჩვენება)"

#: src/qalc.cc:6992
msgid "- cis (show complex numbers in cis form)"
msgstr "- cis (კომპლექსური რიცხვების ჩვენება ცის ფორმატში)"

#: src/qalc.cc:6993
msgid "- angle, phasor (show complex numbers in angle/phasor notation)"
msgstr ""
"- angle, phasor (კომპლექსური რიცხვების ჩვენება კუთხურ/ფაზორის ნოტაციით)"

#: src/qalc.cc:6995
msgid "- fraction, 1/n (show result as mixed fraction)"
msgstr "- fraction, 1/n (შედეგის შერეული წილადის სახით ჩვენება)"

#: src/qalc.cc:6996
msgid "- decimals (show result as decimal fraction)"
msgstr "- decimals (შედეგის ათობით წილადად ჩვენება)"

#: src/qalc.cc:6997
msgid "- 1/# (show as mixed fraction with specified denominator)"
msgstr "- 1/# (შერეული წილადის სახით ჩვენება მითითებული მნიშვნელით)"

#: src/qalc.cc:6998
msgid "prepend with - to show as simple fraction"
msgstr "მარტივ წილადად საჩვენებლად წინ '-' მიუწერეთ"

#: src/qalc.cc:7000
msgid "- sci, scientific (show result with scientific notation)"
msgstr "- sci, scientific (შედეგის სამეცნიერო ნოტაციით ჩვენება)"

#: src/qalc.cc:7001
msgid "- eng, engineering (show result with engineering notation)"
msgstr "- eng, engineering (შედეგის საინჟინრო ნოტაციით ჩვენება)"

#: src/qalc.cc:7002
msgid "- simple (show result with non-scientific notation)"
msgstr "- simple (შედეგის ჩვენება არასამეცნიერო ნოტაციით)"

#: src/qalc.cc:7004
msgid "- factors (factorize result)"
msgstr "- მამრავლები (დაშლის შედეგი)"

#: src/qalc.cc:7006
msgid "- UTC (show date and time in UTC time zone)"
msgstr "- UTC (თარიღისა და დროის UTC დროის სარტყელში ჩვენება)"

#: src/qalc.cc:7007
msgid "- UTC+/-hh[:mm] (show date and time in specified time zone)"
msgstr "- UTC+/-სთ[:წთ] (თარიღისა და დროის ჩვენება მითითებულ დროის სარტყელში)"

#: src/qalc.cc:7008
msgid "- calendars"
msgstr "- კალენდრები"

#: src/qalc.cc:7010
#, fuzzy
#| msgid "- time (show in time format)"
msgid "- latex (show in LaTeX format)"
msgstr "- დრო (დროის ფორმატში ჩვენება)"

#: src/qalc.cc:7012
msgid "Example: to ?g"
msgstr "მაგალითად: to ?g"

#: src/qalc.cc:7015
msgid ""
"This command can also be typed directly at the end of the mathematical "
"expression (e.g. 5 ft + 2 in to meter)."
msgstr ""

#: src/qalc.cc:7020
msgid "Terminates this program."
msgstr "ამ პროგრამის შეწყვეტა."

#: src/qalc.cc:7025
msgid ""
"Implicit multiplication does not differ from explicit multiplication "
"(\"12/2(1+2) = 12/2*3 = 18\", \"5x/5y = 5*x/5*y = xy\")."
msgstr ""

#: src/qalc.cc:7028
msgid ""
"Implicit multiplication is parsed before explicit multiplication "
"(\"12/2(1+2) = 12/(2*3) = 2\", \"5x/5y = (5*x)/(5*y) = x/y\")."
msgstr ""

#: src/qalc.cc:7031
msgid ""
"The default adaptive mode works as the \"implicit first\" mode, unless "
"spaces are found (\"1/5x = 1/(5*x)\", but \"1/5 x = (1/5)*x\"). In the "
"adaptive mode unit expressions are parsed separately (\"5 m/5 m/s = (5*m)/"
"(5*(m/s)) = 1 s\")."
msgstr ""

#: src/qalc.cc:7033
msgid ""
"Function arguments without parentheses are an exception, where implicit "
"multiplication in front of variables and units is parsed first regardless of "
"mode (\"sqrt 2x = sqrt(2x)\")."
msgstr ""

#: src/qalc.cc:7036
msgid ""
"Parse expressions using reverse Polish notation (\"1 2 3+* = 1*(2+3) = 5\")"
msgstr ""
"გამოსახულებების დამუშავება უკუღმა პოლონური ნოტაციის გამოყენებით (\"1 2 3+* = "
"1*(2+3) = 5\")"

#: src/qalc.cc:7039
msgid ""
"Perform operations from left to right, like the immediate execution mode of "
"a traditional calculator (\"1+2*3 = (1+2)*3 = 9\")"
msgstr ""

#: src/qalc.cc:7093
#, c-format
msgid "%s does not accept any arguments."
msgstr "%s არგუმენტებს არ იღებს."

#: src/qalc.cc:7116
#, c-format
msgid "%s requires at least one argument."
msgstr "%s-ს ერთი არგუმენტი მაინც ესაჭიროება."

#: src/qalc.cc:7121
msgid "Unknown command."
msgstr "უცნობ ბრძანება."

#: src/qalc.cc:7218
msgid "error"
msgstr "შეცდომა"

#: src/qalc.cc:7221
msgid "warning"
msgstr "გაფრთხილება"

#: src/qalc.cc:7395
msgid ""
"Please select interpretation of expressions with implicit multiplication."
msgstr ""

#: src/qalc.cc:7399
msgid "Adaptive"
msgstr "შეგუებადი"

#: src/qalc.cc:7404
msgid "Implicit multiplication first"
msgstr "ჯერ მოხდება არაცხადი გამრავლებების ანალიზი"

#: src/qalc.cc:7409
