#: src/qalc.cc:6910
msgid "- unicode"
msgstr "- юникод"

#: src/qalc.cc:6911
msgid "- base # (show in specified number base)"
msgstr "- основание # (показать по указанному основанию)"

#: src/qalc.cc:6912
msgid "- bases (show as binary, octal, decimal and hexadecimal number)"
