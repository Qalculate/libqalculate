msgstr "- bin# (отображается как двоичное число с указанным количеством бит)"

#: src/qalc.cc:6898
msgid "- oct, octal (show as octal number)"
msgstr "- oct, восьмеричное (показать как восьмеричное число)"

#: src/qalc.cc:6899
msgid "- duo, duodecimal (show as duodecimal number)"
msgstr "- duo, двенадцатеричное (показывать как двенадцатеричное число)"

#: src/qalc.cc:6900
msgid "- hex, hexadecimal (show as hexadecimal number)"
msgstr "- hex, шестнадцатеричное (показать как шестнадцатеричное число)"

#: src/qalc.cc:6901
msgid "- hex# (show as hexadecimal number with specified number of bits)"
msgstr ""
"- hex# (показать как шестнадцатеричное число с указанным количеством битов)"

#: src/qalc.cc:6902
msgid "- sexa, sexa2, sexa3, sexagesimal (show as sexagesimal number)"
msgstr ""
"- sexa, sexa2, sexa3, шестидесятеричное (показать как шестидесятеричное "
