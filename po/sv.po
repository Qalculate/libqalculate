msgstr "läs inte in några systemvida dataset"

#: src/qalc.cc:4486
msgid "do not load any global functions from file"
msgstr "läs inte in några systemvida funktioner"

#: src/qalc.cc:4488
msgid "do not load any global units from file"
msgstr "läs inte in några systemvida enheter"

#: src/qalc.cc:4490
msgid "do not load any global variables from file"
msgstr "läs inte in några systemvida variabler"

#: src/qalc.cc:4492
msgid ""
"start in programming mode (same as -b \"BASE BASE\" -s \"xor^\", with base "
"conversion)"
msgstr ""
"starta i programmeringsläge (samma som -b \"BAS BAS\" -s \"xor^\", med "
"basomvandling"

#: src/qalc.cc:4493 src/qalc.cc:6636
msgid "OPTION"
msgstr "INSTÄLLNING"

#: src/qalc.cc:4493 src/qalc.cc:6636
msgid "VALUE"
msgstr "VÄRDE"

#: src/qalc.cc:4494
msgid "as set command in interactive program session (e.g. -set \"base 16\")"
msgstr ""
"fungerar som set (sätt) kommandot i en interaktiv programsession (t.ex. -set "
"\"bas 16\")"

#: src/qalc.cc:4496
