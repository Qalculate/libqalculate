#: data/functions.xml.in:3019
msgid ""
"Returns a date. Available calendars are gregorian (1), hebrew (2), islamic "
"(3), persian (4), indian (5), chinese (6), julian (7), milankovic (8), "
"coptic (9), ethiopian (10), egyptian (11). The Chinese year uses an epoch of "
"2697 BCE and chinese leap months are indicated by adding 12 to the month "
"number (e.g. leap month 4 = 16)."
msgstr ""
"Returnerar ett datum. Tillgängliga kalendrar är grekoriansk (1), hebreisk "
"(2), muslimsk (3), persisk (4), indisk (5), kinesisk (6), juliansk (7), "
"milnkovic (8), koptisk (9), etiopisk (10), egyptisk (11). Det kinesiska året "
"använder en epok som börjar 2697 f.Kr. och kinesiska skottmånader indikeras "
"genom att addera 12 till månadens nummer (t.ex. skottmånad 4 = 16)."

